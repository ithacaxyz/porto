{
  "name": "porto",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun clean && tsc --project ./tsconfig.build.json",
    "build:anvil-state": "bun scripts/build:anvil-state.ts",
    "build:contracts": "bun scripts/prebuild:contracts.ts && forge build --config-path ./contracts/account/foundry.toml && forge build --config-path ./contracts/demo/foundry.toml && bun scripts/postbuild:contracts.ts && bun wagmi generate",
    "changeset:prepublish": "bun build && bun ./scripts/prepublish.ts",
    "changeset:publish": "bun changeset:prepublish && changeset publish",
    "changeset:version": "changeset version && bun format",
    "check": "biome check . --fix --unsafe",
    "check:markdown": "markdownlint-cli2 --config .github/.markdownlint-cli2.jsonc '**/*.md' '**/*.mdx'",
    "check:build": "bun ./scripts/prepublish.ts && publint --strict ./src && attw --pack ./src --profile esm-only",
    "check:knip": "knip --production",
    "check:repo": "sherif --ignore-rule packages-without-package-json",
    "check:size": "size-limit",
    "check:types": "bun --filter='*' check:types && tsc -b",
    "clean": "rm -rf src/_dist ./tsconfig.build.tsbuildinfo src/tsconfig.build.tsbuildinfo",
    "deps": "bunx taze -r",
    "dev": "bun preconstruct && bun --filter playground --filter dialog --filter id dev",
    "dev:anvil": "bun preconstruct && ANVIL=true bun --filter playground --filter dialog --filter id dev",
    "dev:wagmi": "bun preconstruct && bun --filter wagmi-example --filter dialog --filter id dev",
    "docs:build": "bun --filter docs build",
    "docs:dev": "bun --filter docs --filter dialog --filter id dev",
    "format": "biome format --write",
    "postinstall": "git submodule update --init --recursive && bun preconstruct",
    "preconstruct": "bun ./scripts/preconstruct.ts",
    "preinstall": "bunx only-allow bun",
    "prepare": "bun simple-git-hooks",
    "test": "vitest -c ./test/vitest.config.ts --project default",
    "test:browser": "vitest -c ./test/vitest.config.ts --project browser"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.1",
    "@biomejs/biome": "2.0.0-beta.1",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.7",
    "@mjackson/node-fetch-server": "^0.6.1",
    "@size-limit/preset-big-lib": "^11.1.6",
    "@tanstack/react-query": "catalog:",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "@wagmi/cli": "^2.2.0",
    "@wagmi/core": "catalog:",
    "http-proxy": "^1.18.1",
    "knip": "^5.50.5",
    "markdownlint-cli2": "^0.18.1",
    "ox": "catalog:",
    "playwright": "1.53.0",
    "prool": "catalog:",
    "publint": "^0.2.12",
    "sherif": "1.5.0",
    "simple-git-hooks": "^2.11.1",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.4",
    "typed-query-selector": "^2.12.0",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wagmi": "catalog:"
  },
  "packageManager": "bun@1.2.15",
  "workspaces": {
    "packages": [
      "apps/*",
      "docker/*",
      "examples/*",
      "src"
    ],
    "catalog": {
      "@ariakit/react": "^0.4.17",
      "@ariakit/tailwind": "^0.1.7",
      "@iconify/json": "^2.2.347",
      "@sentry/react": "^9",
      "@sentry/vite-plugin": "^3",
      "@svgr/core": "^8.1.0",
      "@svgr/plugin-jsx": "^8.1.0",
      "@tanstack/query-sync-storage-persister": "^5.74.3",
      "@tanstack/react-query": "^5.74.3",
      "@tanstack/react-query-persist-client": "^5.74.3",
      "@tanstack/react-router": "^1.114.25",
      "@tanstack/router-plugin": "^1.114.17",
      "@tanstack/react-query-devtools": "^5.74.3",
      "@tanstack/react-router-devtools": "^1.114.25",
      "@types/node": "^22.14.1",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "@wagmi/core": "^2.17.2",
      "cva": "npm:class-variance-authority@^0.7.1",
      "globals": "^16.0.0",
      "ox": "^0.1.1",
      "prool": "^0.0.23",
      "react": "^19",
      "react-dom": "^19",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.8",
      "@tailwindcss/vite": "^4.1.8",
      "tw-animate-css": "^1.3.4",
      "typescript": "^5.8.3",
      "unplugin-icons": "^22.1.0",
      "viem": "^2.30.6",
      "vite": "^6.0.7",
      "vitest": "^3.1.1",
      "vite-plugin-mkcert": "^1.17.8",
      "wagmi": "^2.15.4",
      "zustand": "^5.0.3",
      "@vitejs/plugin-react": "^4.3.4"
    }
  },
  "engines": {
    "bun": ">=1.2.15",
    "node": ">=22.5"
  },
  "simple-git-hooks": {
    "pre-commit": "bun check"
  },
  "knip": {
    "entry": [
      "src/{index,remote/index,server/index,viem/index,wagmi/index}.ts!"
    ],
    "ignore": [
      "**/test/**",
      "scripts/**",
      "contracts/**",
      "**/internal/**",
      "**/_generated/**",
      "wagmi.config.ts"
    ],
    "ignoreBinaries": [
      "forge"
    ],
    "ignoreUnresolved": [
      "tslib"
    ],
    "ignoreWorkspaces": [
      "apps/**",
      "examples/**"
    ],
    "ignoreDependencies": [
      "react",
      "wagmi",
      "@wagmi/*",
      "@tanstack/react-query",
      "@size-limit/preset-big-lib"
    ]
  },
  "size-limit": [
    {
      "name": "import * from 'ox'",
      "path": "./src/_dist/index.js",
      "import": "*"
    }
  ],
  "bun": {
    "patchedDependencies": {
      "@tanstack/react-router": "patches/@tanstack__react-router.patch",
      "@wagmi/cli": "patches/@wagmi__cli.patch",
      "@wagmi/core": "patches/@wagmi__core.patch",
      "@vitest/browser": "patches/@vitest__browser.patch"
    }
  },
  "trustedDependencies": [
    "esbuild",
    "sharp",
    "@sentry/cli",
    "@tailwindcss/oxide"
  ]
}

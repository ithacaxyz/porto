{
  "$schema": "https://esm.sh/wrangler/config-schema.json",
  "name": "wallet",
  "keep_vars": true,
  "workers_dev": true,
  "main": "./api/index.ts",
  "compatibility_date": "2025-02-24",
  "compatibility_flags": ["nodejs_als", "nodejs_compat"],
  "dev": {
    "port": 6901
  },
  "placement": {
    "mode": "smart"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "NODE_VERSION": "23.9.0",
    "PNPM_VERSION": "10.6.1",
    "VITE_LAUNCH_MODE": "app",
    "VITE_ENABLE_DEV_TOOLS": true
  }
}

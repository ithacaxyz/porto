{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": ["./src/**/*"],
  "files": [
    "env.d.ts",
    "package.json",
    "wrangler.json",
    "vite.config.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["**/_/**", "dist", "node_modules"]
}
